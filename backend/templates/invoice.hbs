<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Invoice #{{orderId}}</title>
    <style>
        @page {
            size: A4;
            margin: 0;
        }
        body {
            font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #1e293b;
            line-height: 1.4;
            background: #fff;
            width: 210mm;
            min-height: 297mm;
        }
        .container {
            padding: 30px;
        }
        .header {
            background-color: #4f46e5;
            color: white;
            padding: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .logo {
            font-size: 36px;
            font-weight: 900;
            color: white;
            letter-spacing: -1px;
        }
        .invoice-title {
            text-align: right;
        }
        .invoice-title h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 900;
            color: white;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .invoice-title p {
            margin: 4px 0 0 0;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.8);
            font-weight: 600;
        }
        .address-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 35px;
            padding: 0 10px;
        }
        .address-box {
            width: 45%;
        }
        .address-box h3 {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 12px;
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 6px;
            letter-spacing: 1px;
        }
        .address-box p {
            margin: 3px 0;
            font-size: 14px;
        }
        .address-box strong {
            font-size: 16px;
            color: #0f172a;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }
        th {
            background-color: #f8fafc;
            text-align: left;
            padding: 12px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            color: #64748b;
            border-bottom: 2px solid #e2e8f0;
            letter-spacing: 0.5px;
        }
        td {
            padding: 15px 12px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 14px;
            vertical-align: top;
        }
        .item-name {
            font-weight: 700;
            color: #0f172a;
            display: block;
            margin-bottom: 4px;
        }
        .item-seller {
            font-size: 11px;
            color: #64748b;
            font-weight: 500;
        }
        .summary {
            display: flex;
            justify-content: flex-end;
            padding: 0 10px;
            page-break-inside: avoid;
        }
        .summary-box {
            width: 38%;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 14px;
            color: #475569;
        }
        .summary-row.total {
            border-top: 2px solid #4f46e5;
            margin-top: 15px;
            padding-top: 20px;
            font-weight: 900;
            font-size: 20px;
            color: #4f46e5;
        }
        .footer {
            margin-top: 50px;
            padding: 30px;
            border-top: 1px solid #f1f5f9;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            page-break-inside: avoid;
        }
        .footer p {
            margin: 4px 0;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">Zapify</div>
        <div class="invoice-title">
            <h1>INVOICE</h1>
            <p>#{{orderId}}</p>
            <p>{{formatDate date}}</p>
        </div>
    </div>

    <div class="container">
        <div class="address-row">
            <div class="address-box">
                <h3>Billed To</h3>
                <p><strong>{{customerName}}</strong></p>
                <p>{{customerEmail}}</p>
            </div>
            <div class="address-box">
                <h3>Shipping Address</h3>
                <p><strong>{{address.fullname}}</strong></p>
                <p>{{address.addressLine1}}</p>
                {{#if address.addressLine2}}<p>{{address.addressLine2}}</p>{{/if}}
                <p>{{address.city}}, {{address.state}} - {{address.pincode}}</p>
            </div>
        </div>

        <table>
        <thead>
            <tr>
                <th>Description</th>
                <th style="text-align: center;">Qty</th>
                <th style="text-align: right;">Unit Price</th>
                <th style="text-align: right;">Total</th>
            </tr>
        </thead>
            {{#each items}}
            <tr>
                <td>
                    <span class="item-name">{{productName}}</span>
                    <span class="item-seller">Sold by: {{sellerStore}}</span>
                </td>
                <td style="text-align: center;">{{quantity}}</td>
                <td style="text-align: right;">{{formatCurrency priceAtTimeOfPurchase}}</td>
                <td style="text-align: right; font-weight: 700;">{{formatCurrency itemTotal}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="summary">
        <div class="summary-box">
            <div class="summary-row">
                <span>Subtotal</span>
                <span style="font-weight: 600;">{{formatCurrency subtotal}}</span>
            </div>
            <div class="summary-row">
                <span>Tax (GST {{taxRate}}%)</span>
                <span style="font-weight: 600;">{{formatCurrency taxAmount}}</span>
            </div>
            {{#if discount}}
            <div class="summary-row" style="color: #059669; font-weight: 600;">
                <span>Discount</span>
                <span>-{{formatCurrency discount}}</span>
            </div>
            {{/if}}
            <div class="summary-row total">
                <span>Amount Paid</span>
                <span>{{formatCurrency total}}</span>
            </div>
        </div>
    </div>

    <div class="footer">
        <p style="font-weight: 700; color: #475569; font-size: 14px; margin-bottom: 8px;">Thank you for shopping with Zapify!</p>
        <p>This is a computer-generated invoice and does not require a physical signature.</p>
        <p>Zapify Marketplace • 123 Commerce St • Digital City • support@zapify.com</p>
    </div>
    </div> <!-- Close .container -->
</body>
</html>
